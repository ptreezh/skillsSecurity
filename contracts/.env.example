# Polygon Amoy Testnet Configuration
# Copy this file to .env and fill in your values

# RPC URL (Polygon Amoy - chainId 80002)
# Optional: Use your own RPC provider (Infura, Alchemy, etc.)
POLYGON_AMOY_RPC=https://rpc-amoy.polygon.technology

# Private key of your deployer wallet (DO NOT COMMIT THIS FILE!)
# Must start with 0x
PRIVATE_KEY=0x...

# Polygonscan API Key (for contract verification on Polygonscan)
# Get from: https://polygonscan.com/apis
POLYGONSCAN_API_KEY=your_api_key_here