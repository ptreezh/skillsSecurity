# AgentSkills Environment Variables Template
# Copy this file to .env and fill in your values

# ========================
# Network Configuration
# ========================

# Polygon Mainnet RPC (free, no API key needed)
POLYGON_RPC=https://rpc.ankr.com/polygon

# Polygon Amoy Testnet RPC (free)
POLYGON_AMOY_RPC=https://rpc-amoy.polygon.technology

# ========================
# Deployment
# ========================

# Wallet private key for deployment
# WARNING: Never commit this file or expose your private key!
# Export from MetaMask: Account Details → Export Private Key
# Format: 0x followed by 64 hex characters
PRIVATE_KEY=

# ========================
# Monitoring (Optional)
# ========================

# Telegram Bot for alerts (optional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Gas alert thresholds (Gwei)
GAS_FAST_THRESHOLD=100
GAS_STANDARD_THRESHOLD=50
GAS_SLOW_THRESHOLD=20

# ========================
# Contract Addresses
# ========================

# These will be filled after deployment
STAKING_MANAGER_ADDRESS=
SKILL_REGISTRY_ADDRESS=
ATTRIBUTION_ADDRESS=
GOVERNANCE_TIMELOCK_ADDRESS=